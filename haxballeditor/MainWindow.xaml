<Window x:Class="haxballeditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="HaxStudio"
        Height="880"
        Width="1520"
        MinHeight="780"
        MinWidth="1220"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#161719">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#111317"/>
        <SolidColorBrush x:Key="TopBarBg" Color="#181B20"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1C1F24"/>
        <SolidColorBrush x:Key="PanelDarker" Color="#15171B"/>
        <SolidColorBrush x:Key="PanelSoft" Color="#242832"/>
        <SolidColorBrush x:Key="PanelHover" Color="#2B303B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#343A45"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#2A3039"/>
        <SolidColorBrush x:Key="TextMain" Color="#E8EDF4"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9DA7B5"/>
        <SolidColorBrush x:Key="Accent" Color="#2FB7E8"/>
        <SolidColorBrush x:Key="AccentHover" Color="#3AC7FA"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#173546"/>
        <SolidColorBrush x:Key="DangerSoft" Color="#3A2020"/>
        <SolidColorBrush x:Key="DangerBorder" Color="#714444"/>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.22" Color="#000000"/>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#0F1116"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Height" Value="30"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#0F1116"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E8EDF4"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A3038"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
            </Style.Resources>
        </Style>

        <ControlTemplate x:Key="TopLevelMenuItemTemplate" TargetType="{x:Type MenuItem}">
            <Grid SnapsToDevicePixels="True">
                <Border x:Name="TopLevelBorder"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4"
                        Margin="2,3">
                    <ContentPresenter ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                </Border>

                <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       PopupAnimation="Fade">
                    <Border Background="#202226"
                            BorderBrush="#3B4048"
                            BorderThickness="1"
                            Padding="4"
                            MinWidth="190"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
                        </Border.Effect>
                        <ScrollViewer CanContentScroll="True"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="TopLevelBorder" Property="Background" Value="#252A32"/>
                    <Setter TargetName="TopLevelBorder" Property="BorderBrush" Value="#38414E"/>
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="TopLevelBorder" Property="Background" Value="#1E5A78"/>
                    <Setter TargetName="TopLevelBorder" Property="BorderBrush" Value="#2F86B0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SubmenuItemTemplate" TargetType="{x:Type MenuItem}">
            <Grid SnapsToDevicePixels="True">
                <Border x:Name="ItemBorder"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="3"
                        Height="26"
                        Margin="0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="MenuCheckMark"
                                   Grid.Column="0"
                                   Text="OK"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <ContentPresenter Grid.Column="1"
                                          ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>

                        <TextBlock x:Name="SubmenuArrow"
                                   Grid.Column="2"
                                   Text=">"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <Popup x:Name="PART_Popup"
                       Placement="Right"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       PopupAnimation="Fade">
                    <Border Background="#202226"
                            BorderBrush="#3B4048"
                            BorderThickness="1"
                            Padding="4"
                            MinWidth="190"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
                        </Border.Effect>
                        <ScrollViewer CanContentScroll="True"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="True">
                    <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#2A3038"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#38414E"/>
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#243646"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2F86B0"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="MenuCheckMark" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template" Value="{StaticResource SubmenuItemTemplate}"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#202226"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E8EDF4"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A3038"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202226"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E8EDF4"/>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}"/>
                </Trigger>
                <Trigger Property="Role" Value="TopLevelItem">
                    <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="22,5,8,5"/>
            <Setter Property="Background" Value="#343A44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonBase" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#242832"/>
            <Setter Property="BorderBrush" Value="#3A414D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E3541"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#526071"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D222B"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <Style x:Key="PrimaryTopButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
            <Setter Property="Background" Value="#123A50"/>
            <Setter Property="BorderBrush" Value="#2E7DA0"/>
            <Setter Property="Foreground" Value="#F2FBFF"/>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="78"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="Margin" Value="5,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#20252E"/>
            <Setter Property="BorderBrush" Value="#333C48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3340"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#506177"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#162C3A"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,7"/>
        </Style>

        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,7,0,3"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#12151A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="#333A46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#326F91"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Root" Property="Background" Value="#151A21"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#171A20"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="Root"
                    Background="#12151A"
                    BorderBrush="#333A46"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1"
                            Background="#181D24"
                            BorderBrush="#333A46"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,8,8,0"/>

                    <Path Grid.Column="1"
                          Data="M 0 0 L 4 4 L 8 0 Z"
                          Fill="#C7D0DC"
                          Width="8"
                          Height="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="#171C23"/>
                    <Setter TargetName="Root" Property="BorderBrush" Value="#4C5A6B"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="#151A21"/>
                    <Setter TargetName="Root" Property="BorderBrush" Value="#2FB7E8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#12151A"/>
            <Setter Property="Foreground" Value="#E8EDF5"/>
            <Setter Property="BorderBrush" Value="#333A46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButtonTemplate}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="9,0,34,0"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     Margin="8,0,34,0"
                                     VerticalAlignment="Center"/>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Background="#12151A"
                                            BorderBrush="#3C4654"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <ScrollViewer Margin="3" SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#2FB7E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}"/>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#12151A"/>
            <Setter Property="Foreground" Value="#E8EDF5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#24364A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#0E639C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#20252E"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="3,0,3,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#303743"
                                BorderThickness="1,1,1,0"
                                CornerRadius="9,9,0,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#2B3340"/>
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#455366"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#123A50"/>
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#2E7DA0"/>
                                <Setter Property="Foreground" Value="#F2FBFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#12151A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="#333A46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Margin" Value="0,4,10,0"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#191D23"/>
            <Setter Property="BorderBrush" Value="#2E3540"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
            <Setter Property="Padding" Value="9"/>
        </Style>


        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#202226"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="#3B4048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkContextMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                MinWidth="150"
                                Margin="0,1">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A3038"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#38414E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkContextSeparator" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="6,5"/>
            <Setter Property="Background" Value="#343A44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#252A32"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A1E25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B3261E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7F1D1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="29"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B0D10" BorderBrush="#252B33" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,14,0" IsHitTestVisible="False">
                        <Border Width="22" Height="22" CornerRadius="6" Background="#122B38" BorderBrush="#2FB7E8" BorderThickness="1" Margin="0,0,8,0">
                            <TextBlock Text="H" Foreground="#BFF4FF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="HaxStudio" Foreground="#F2FBFF" FontSize="13.5" FontWeight="Bold" LineHeight="13"/>
                            <TextBlock Text="Stadium Editor" Foreground="#7F8B99" FontSize="9.5" FontWeight="SemiBold" LineHeight="10"/>
                        </StackPanel>
                    </StackPanel>

                    <Menu Background="#0B0D10" Height="36" VerticalAlignment="Stretch" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <MenuItem Header="File">
                            <MenuItem Header="New Stadium" Click="NewButton_Click"/>
                            <MenuItem Header="Open .hbs" Click="OpenButton_Click"/>
                            <MenuItem Header="Save" Click="SaveButton_Click"/>
                            <MenuItem Header="Save As" Click="SaveAsButton_Click"/>
                            <Separator/>
                            <MenuItem Header="Exit" Click="ExitButton_Click"/>
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Undo" Click="UndoButton_Click"/>
                            <MenuItem Header="Redo" Click="RedoButton_Click"/>
                            <Separator/>
                            <MenuItem Header="Copy" Click="CopyButton_Click"/>
                            <MenuItem Header="Paste" Click="PasteButton_Click"/>
                            <MenuItem Header="Duplicate" Click="DuplicateButton_Click"/>
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem x:Name="SnapToGridMenuItem" Header="Snap to Grid" IsCheckable="True" Click="SnapToGridButton_Click"/>
                        </MenuItem>
                        <MenuItem Header="Tools">
                            <MenuItem x:Name="SelectToolMenuItem" Header="Select" InputGestureText="Ctrl+L" IsCheckable="True" Click="SelectTool_Click"/>
                            <MenuItem x:Name="AddVertexToolMenuItem" Header="Add Vertex" InputGestureText="Ctrl+E" IsCheckable="True" Click="AddVertexButton_Click"/>
                            <MenuItem x:Name="AddSegmentToolMenuItem" Header="Add Segment" InputGestureText="Ctrl+T" IsCheckable="True" Click="AddSegmentButton_Click"/>
                            <MenuItem x:Name="AddDiscToolMenuItem" Header="Add Disc" InputGestureText="Ctrl+I" IsCheckable="True" Click="AddDiscButton_Click"/>
                            <MenuItem x:Name="AddGoalToolMenuItem" Header="Add Goal" InputGestureText="Ctrl+G" IsCheckable="True" Click="AddGoalButton_Click"/>
                            <MenuItem x:Name="AddPlaneToolMenuItem" Header="Add Plane" InputGestureText="Ctrl+P" IsCheckable="True" Click="AddPlaneButton_Click"/>
                            <MenuItem x:Name="AddRedSpawnToolMenuItem" Header="Add Red Spawn" InputGestureText="Ctrl+R" IsCheckable="True" Click="AddRedSpawnButton_Click"/>
                            <MenuItem x:Name="AddBlueSpawnToolMenuItem" Header="Add Blue Spawn" InputGestureText="Ctrl+B" IsCheckable="True" Click="AddBlueSpawnButton_Click"/>
                        </MenuItem>
                        <MenuItem Header="Settings" Click="SettingsMenu_Click"/>
                    </Menu>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="HaxStudio" Foreground="{StaticResource TextMuted}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="-" Style="{StaticResource WindowControlButton}" Click="MinimizeWindowButton_Click" ToolTip="Minimize"/>
                    <Button x:Name="MaximizeRestoreWindowButton" Content="[]" Style="{StaticResource WindowControlButton}" Click="MaximizeRestoreWindowButton_Click" ToolTip="Maximize / Restore"/>
                    <Button Content="X" Style="{StaticResource CloseWindowButton}" Click="CloseWindowButton_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource TopBarBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,9">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="New" Style="{StaticResource TopButton}" Click="NewButton_Click"/>
                    <Button Content="Open" Style="{StaticResource TopButton}" Click="OpenButton_Click"/>
                    <Button Content="Save" Style="{StaticResource TopButton}" Click="SaveButton_Click"/>
                    <Button Content="Save As" Style="{StaticResource TopButton}" Click="SaveAsButton_Click"/>
                    <Button Content="Validate" Style="{StaticResource TopButton}" Click="ValidateButton_Click" ToolTip="Validate stadium data"/>
                    <Rectangle Width="1" Height="24" Fill="#3A3E44" Margin="10,0"/>
                    <CheckBox x:Name="SnapToGridCheckBox" Content="Snap" VerticalAlignment="Center" Margin="2,0,5,0" Checked="SnapToGridCheckBox_Changed" Unchecked="SnapToGridCheckBox_Changed" ToolTip="Snap moved/created points to grid"/>
                    <TextBox x:Name="SnapGridSizeTextBox" Width="46" Height="30" Text="25" Style="{StaticResource InputTextBox}" ToolTip="Snap grid size" LostFocus="SnapGridSizeTextBox_LostFocus" KeyDown="SnapGridSizeTextBox_KeyDown"/>
                    <Rectangle Width="1" Height="24" Fill="#3A3E44" Margin="10,0"/>
                    <Button x:Name="SelectToolButton" Content="Select" ToolTip="Select tool (Ctrl+L)" Style="{StaticResource PrimaryTopButton}" Click="SelectTool_Click"/>
                    <Button x:Name="AddVertexToolButton" Content="Vertex" ToolTip="Add Vertex (Ctrl+E)" Style="{StaticResource TopButton}" Click="AddVertexButton_Click"/>
                    <Button x:Name="AddSegmentToolButton" Content="Segment" ToolTip="Add Segment (Ctrl+T)" Style="{StaticResource TopButton}" Click="AddSegmentButton_Click"/>
                    <Button x:Name="AddDiscToolButton" Content="Disc" ToolTip="Add Disc (Ctrl+I)" Style="{StaticResource TopButton}" Click="AddDiscButton_Click"/>
                    <Button x:Name="AddGoalToolButton" Content="Goal" ToolTip="Add Goal (Ctrl+G)" Style="{StaticResource TopButton}" Click="AddGoalButton_Click"/>
                    <Button x:Name="AddPlaneToolButton" Content="Plane" ToolTip="Add Plane (Ctrl+P)" Style="{StaticResource TopButton}" Click="AddPlaneButton_Click"/>
                    <Button x:Name="AddRedSpawnToolButton" Content="Red Spawn" ToolTip="Add Red Spawn (Ctrl+R)" Style="{StaticResource TopButton}" Click="AddRedSpawnButton_Click"/>
                    <Button x:Name="AddBlueSpawnToolButton" Content="Blue Spawn" ToolTip="Add Blue Spawn (Ctrl+B)" Style="{StaticResource TopButton}" Click="AddBlueSpawnButton_Click"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#12151A" BorderBrush="#303845" BorderThickness="1" Padding="12,5" CornerRadius="10">
                    <TextBlock Text="Ctrl+Z/Y  -  Ctrl+C/V/D  -  Tools: Ctrl+L/E/T/I/G/P/R/B"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="580"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="420" MinWidth="320" MaxWidth="820"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" ClipToBounds="True">
                <Grid ClipToBounds="True">
                    <Border Height="36" VerticalAlignment="Top" Background="#1C1D20" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="5">
                        <DockPanel Margin="10,0">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Viewport" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource AccentSoft}" BorderBrush="#245B76" BorderThickness="1" Padding="7,2" CornerRadius="3" Margin="12,0,0,0">
                                    <TextBlock x:Name="ViewportInfoText" Text="Zoom: 100% | Pan: 0, 0" Foreground="#BBDCEE" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="CurrentToolText" Text="Select" Visibility="Collapsed"/>
                                <TextBlock x:Name="SegmentFirstVertexText" Text="None" Visibility="Collapsed"/>
                                <TextBlock x:Name="MousePositionText" Text="HaxBall X: 0  Y: 0" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Margin="0,36,0,0" Background="#3B2E29" ClipToBounds="True">
                        <Canvas x:Name="MapCanvas"
                                Background="#3B2E29"
                                ClipToBounds="True"
                                Focusable="True"
                                MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                                MouseMove="MapCanvas_MouseMove"
                                MouseWheel="MapCanvas_MouseWheel"
                                MouseDown="MapCanvas_MouseDown"
                                MouseUp="MapCanvas_MouseUp"
                                SizeChanged="MapCanvas_SizeChanged"/>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#242A33"
                          BorderBrush="#3A4350"
                          BorderThickness="1,0"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Cursor="SizeWE"
                          ToolTip="Drag to resize the right panel"/>

            <Border Grid.Column="2" Background="{StaticResource PanelDark}">
                <TabControl>
                    <TabItem Header="Inspector">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <Expander x:Name="SelectionExpander" Header="Selection / Coordinates" IsExpanded="True">
                                    <StackPanel>
                                        <TextBlock Text="Selected Object" Style="{StaticResource PropertyLabel}"/>
                                        <TextBox x:Name="SelectedObjectText" Text="None" IsReadOnly="True" Style="{StaticResource InputTextBox}"/>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Position / Data A" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PositionXTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Position / Data B" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PositionYTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#151A21" BorderBrush="#303844" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Selection Info" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="SelectionInfoTextBlock"
                                                           Text="No selection"
                                                           Foreground="{StaticResource TextMain}"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Expander x:Name="CollisionExpander" Header="Collision Checkboxes (legacy)" IsExpanded="False" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Collision Group" Style="{StaticResource PropertyLabel}"/>
                                                <WrapPanel>
                                                    <CheckBox x:Name="CGroupBallCheckBox" Content="ball" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupRedCheckBox" Content="red" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupBlueCheckBox" Content="blue" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupWallCheckBox" Content="wall" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                </WrapPanel>
                                                <TextBlock Text="Collision Mask" Style="{StaticResource PropertyLabel}" Margin="0,10,0,3"/>
                                                <WrapPanel>
                                                    <CheckBox x:Name="CMaskBallCheckBox" Content="ball" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskRedCheckBox" Content="red" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskBlueCheckBox" Content="blue" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskWallCheckBox" Content="wall" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="MultiPropertiesExpander" Header="Multi-Select Common Properties" IsExpanded="True" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Applies only to selected object types that support each property. Leave a field empty to keep it unchanged."
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiColorTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: #FFFFFF. Applies to Segment, Disc and Joint."/>
                                                <TextBlock Text="Trait" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiTraitTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Applies to Segment, Disc and Plane."/>
                                                <TextBlock Text="Visibility" Style="{StaticResource PropertyLabel}"/>
                                                <ComboBox x:Name="MultiVisComboBox" SelectedIndex="0" ToolTip="Applies to Segment, Disc and Plane vis extension.">
                                                    <ComboBoxItem Content="Keep"/>
                                                    <ComboBoxItem Content="True"/>
                                                    <ComboBoxItem Content="False"/>
                                                    <ComboBoxItem Content="Default"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="cMask" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiCMaskTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: ball, red, blue, wall. Applies to Segment, Disc and Plane."/>
                                                <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiCGroupTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: wall. Applies to Segment, Disc and Plane."/>
                                                <Button Content="Apply Common Properties"
                                                        Style="{StaticResource SmallButton}"
                                                        HorizontalAlignment="Stretch"
                                                        Margin="0,16,0,0"
                                                        Click="ApplyMultiPropertiesButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="ObjectPropertiesExpander" Header="Object Properties" IsExpanded="True">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel x:Name="ObjectXFieldPanel">
                                                    <TextBlock Text="X" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectXTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="ObjectYFieldPanel">
                                                    <TextBlock Text="Y" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectYTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="RadiusFieldPanel">
                                                    <TextBlock Text="Radius" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="RadiusTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="CurveFieldPanel">
                                                    <TextBlock Text="Curve" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CurveTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="InvMassFieldPanel">
                                                    <TextBlock Text="invMass" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="InvMassTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="DampingFieldPanel">
                                                    <TextBlock Text="damping" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="DampingTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <StackPanel x:Name="ColorFieldPanel">
                                                    <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectColorTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="BCoefFieldPanel">
                                                    <TextBlock Text="bCoef" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="BCoefTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="SpeedFieldPanel">
                                                    <TextBlock Text="speed X / Y" Style="{StaticResource PropertyLabel}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="SpeedXTextBox" Grid.Column="0" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                        <TextBox x:Name="SpeedYTextBox" Grid.Column="2" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="GravityFieldPanel">
                                                    <TextBlock Text="gravity X / Y" Style="{StaticResource PropertyLabel}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="GravityXTextBox" Grid.Column="0" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                        <TextBox x:Name="GravityYTextBox" Grid.Column="2" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="TraitFieldPanel">
                                                    <TextBlock Text="trait" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="TraitTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="BiasFieldPanel">
                                                    <TextBlock Text="bias" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="BiasTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="VisFieldPanel">
                                                    <TextBlock Text="vis" Style="{StaticResource PropertyLabel}"/>
                                                    <ComboBox x:Name="VisComboBox" SelectionChanged="VisComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Default"/>
                                                        <ComboBoxItem Content="true"/>
                                                        <ComboBoxItem Content="false"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel x:Name="CollisionTextFieldsPanel" Margin="0,10,0,0">
                                            <TextBlock Text="Collision" Style="{StaticResource PropertyLabel}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="cMask" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CMaskTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Comma separated: ball, red, blue, wall, redKO, blueKO, c0..." LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CGroupTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Comma separated: ball, red, blue, wall, redKO, blueKO, c0..." LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="GoalTeamExpander" Header="Goal Team" IsExpanded="False">
                                    <StackPanel>
                                        <ComboBox x:Name="GoalTeamComboBox" SelectedIndex="0" SelectionChanged="GoalTeamComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Red"/>
                                            <ComboBoxItem Content="Blue"/>
                                        </ComboBox>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Button Content="Set Red" Style="{StaticResource SmallButton}" Click="GoalTeamRedButton_Click"/>
                                            <Button Content="Set Blue" Style="{StaticResource SmallButton}" Click="GoalTeamBlueButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="JointToolExpander" Header="Joint Tool" IsExpanded="False">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="disc index 0" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="JointD0TextBox" Text="0" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="disc index 1" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="JointD1TextBox" Text="1" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Button Content="Add Joint From Indices" Style="{StaticResource SmallButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="AddJointButton_Click"/>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="BackgroundExpander" Header="Background" IsExpanded="False">
                                    <StackPanel>
                                        <TextBlock Text="Type" Style="{StaticResource PropertyLabel}"/>
                                        <ComboBox x:Name="BgTypeComboBox" SelectionChanged="BgTypeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="Grass"/>
                                            <ComboBoxItem Content="Hockey"/>
                                        </ComboBox>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgColorTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                                <TextBlock Text="Width" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgWidthTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Height" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgHeightTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                                <TextBlock Text="KickOff Radius" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgKickOffRadiusTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Corner Radius" Style="{StaticResource PropertyLabel}"/>
                                        <TextBox x:Name="BgCornerRadiusTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Layers">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Objects" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Search, filter, click to select, double-click to focus in viewport." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Search" Style="{StaticResource PropertyLabel}" Margin="0,0,0,3"/>
                                    <TextBox x:Name="LayersSearchTextBox"
                                             Style="{StaticResource InputTextBox}"
                                             ToolTip="Search object type, index, coordinates, color, collision values."
                                             TextChanged="LayersSearchTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Type Filter" Style="{StaticResource PropertyLabel}" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="LayersTypeFilterComboBox"
                                              SelectedIndex="0"
                                              SelectionChanged="LayersTypeFilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="All"/>
                                        <ComboBoxItem Content="Vertexes"/>
                                        <ComboBoxItem Content="Segments"/>
                                        <ComboBoxItem Content="Discs"/>
                                        <ComboBoxItem Content="Goals"/>
                                        <ComboBoxItem Content="Planes"/>
                                        <ComboBoxItem Content="Spawn Points"/>
                                        <ComboBoxItem Content="Joints"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Hide" Style="{StaticResource SmallButton}" Click="HideSelectedLayerButton_Click" ToolTip="Hide selected object(s) in the editor viewport"/>
                                <Button Content="Show All" Style="{StaticResource SmallButton}" Click="ShowAllLayersButton_Click" ToolTip="Show all hidden objects"/>
                                <Button Content="Lock" Style="{StaticResource SmallButton}" Click="LockSelectedLayerButton_Click" ToolTip="Lock selected object(s) against moving/deleting from viewport"/>
                                <Button Content="Unlock All" Style="{StaticResource SmallButton}" Click="UnlockAllLayersButton_Click" ToolTip="Unlock all objects"/>
                            </StackPanel>

                            <ListBox x:Name="ObjectsListBox"
                                     Grid.Row="3"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     SelectionChanged="ObjectsListBox_SelectionChanged"
                                     MouseDoubleClick="ObjectsListBox_MouseDoubleClick"/>
                        </Grid>
                    </TabItem>


                    <TabItem Header="Validator">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Stadium Validator" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Checks invalid indexes, unsafe values, colors and collision groups. Double-click a result to focus the related object." Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="#151A21" BorderBrush="#303844" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock x:Name="ValidationSummaryText" Text="Not validated yet." Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ValidationDetailsText" Text="Press Validate to scan the current stadium." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="Validate" Style="{StaticResource SmallButton}" Click="ValidateButton_Click"/>
                                </DockPanel>
                            </Border>

                            <ListBox x:Name="ValidationResultsListBox"
                                     Grid.Row="2"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     MouseDoubleClick="ValidationResultsListBox_MouseDoubleClick"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="JSON">
                        <Grid Background="#1A1B1E">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#202124" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <DockPanel Margin="10,0">
                                    <TextBlock Text="Editable Stadium JSON" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <Button Content="Apply JSON" Style="{StaticResource SmallButton}" Click="ApplyJsonButton_Click"/>
                                        <Button Content="Refresh" Style="{StaticResource SmallButton}" Click="RefreshJsonButton_Click"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Grid.Row="1" Margin="10" Background="#0F1012" BorderBrush="#34373C" BorderThickness="1">
                                <TextBox x:Name="JsonPreviewTextBox"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalAlignment="Stretch"
                                         HorizontalAlignment="Stretch"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Padding="12"
                                         Background="#0F1012"
                                         Foreground="#DCDCDC"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         TextChanged="JsonPreviewTextBox_TextChanged"/>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0F6FA5" BorderBrush="#0A577F" BorderThickness="0,1,0,0">
            <DockPanel Margin="10,0">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="White" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock x:Name="ObjectCountText" Text="Vertexes: 0 | Segments: 0 | Goals: 0 | Planes: 0 | Discs: 0 | Joints: 0 | Spawns: 0" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>