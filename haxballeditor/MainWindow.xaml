                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="-" Style="{StaticResource WindowControlButton}" Click="MinimizeWindowButton_Click" ToolTip="Minimize"/>
                    <Button x:Name="MaximizeRestoreWindowButton" Style="{StaticResource WindowControlButton}" Click="MaximizeRestoreWindowButton_Click" ToolTip="Maximize / Restore">
                        <materialDesign:PackIcon Kind="WindowMaximize" Style="{StaticResource WindowTitleIcon}"/>
                    </Button>
                    <Button Style="{StaticResource CloseWindowButton}" Click="CloseWindowButton_Click" ToolTip="Close">
                        <materialDesign:PackIcon Kind="WindowClose" Style="{StaticResource WindowTitleIcon}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource TopBarBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,9">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource TopButton}" Click="NewButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePlus" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="New"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopButton}" Click="OpenButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Open"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopButton}" Click="SaveButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopButton}" Click="SaveAsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSaveEdit" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Save As"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Height="24" Fill="#3A3E44" Margin="10,0"/>
                    <CheckBox x:Name="SnapToGridCheckBox" Content="Snap" VerticalAlignment="Center" Margin="2,0,5,0" Checked="SnapToGridCheckBox_Changed" Unchecked="SnapToGridCheckBox_Changed" ToolTip="Snap moved/created points to grid"/>
                    <TextBox x:Name="SnapGridSizeTextBox" Width="46" Height="30" Text="25" Style="{StaticResource InputTextBox}" ToolTip="Snap grid size" LostFocus="SnapGridSizeTextBox_LostFocus" KeyDown="SnapGridSizeTextBox_KeyDown"/>
                    <Rectangle Width="1" Height="24" Fill="#3A3E44" Margin="10,0"/>
                    <Button x:Name="SelectToolButton" Style="{StaticResource PrimaryTopButton}" Click="SelectTool_Click" ToolTip="Select tool (Ctrl+L)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CursorDefaultClick" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Select"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddVertexToolButton" Style="{StaticResource TopButton}" Click="AddVertexButton_Click" ToolTip="Add Vertex (Ctrl+E)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="VectorPoint" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Vertex"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddSegmentToolButton" Style="{StaticResource TopButton}" Click="AddSegmentButton_Click" ToolTip="Add Segment (Ctrl+T)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="VectorLine" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Segment"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddDiscToolButton" Style="{StaticResource TopButton}" Click="AddDiscButton_Click" ToolTip="Add Disc (Ctrl+I)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CircleOutline" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Disc"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddGoalToolButton" Style="{StaticResource TopButton}" Click="AddGoalButton_Click" ToolTip="Add Goal (Ctrl+G)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Soccer" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Goal"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddPlaneToolButton" Style="{StaticResource TopButton}" Click="AddPlaneButton_Click" ToolTip="Add Plane (Ctrl+P)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AxisArrow" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Plane"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddRedSpawnToolButton" Style="{StaticResource TopButton}" Click="AddRedSpawnButton_Click" ToolTip="Add Red Spawn (Ctrl+R)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountArrowRight" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Red Spawn"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddBlueSpawnToolButton" Style="{StaticResource TopButton}" Click="AddBlueSpawnButton_Click" ToolTip="Add Blue Spawn (Ctrl+B)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountArrowLeft" Style="{StaticResource ToolbarIcon}"/>
                            <TextBlock Text="Blue Spawn"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#12151A" BorderBrush="#303845" BorderThickness="1" Padding="12,5" CornerRadius="10">
                    <TextBlock Text="Ctrl+Z/Y  -  Ctrl+C/V/D  -  Tools: Ctrl+L/E/T/I/G/P/R/B"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="12"/>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="0" MinWidth="0" MaxWidth="820"/>
                <ColumnDefinition x:Name="LeftPanelSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="ViewportColumn" Width="*" MinWidth="580"/>
                <ColumnDefinition x:Name="RightPanelSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="0" MinWidth="0" MaxWidth="820"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftPanelHost"
                    Grid.Column="0"
                    Background="{StaticResource PanelDark}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0"
                    Visibility="Collapsed">
                <TabControl x:Name="LeftPanelTabControl"/>
            </Border>

            <GridSplitter x:Name="LeftPanelGridSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#242A33"
                          BorderBrush="#3A4350"
                          BorderThickness="1,0"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Cursor="SizeWE"
                          Visibility="Collapsed"
                          ToolTip="Drag to resize the left panel"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ViewportRow" Height="*" MinHeight="320"/>
                    <RowDefinition x:Name="BottomPanelSplitterRow" Height="0"/>
                    <RowDefinition x:Name="BottomPanelRow" Height="0" MinHeight="0" MaxHeight="520"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#111" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <Grid ClipToBounds="True">
                        <Border Height="36" VerticalAlignment="Top" Background="#1C1D20" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="5">
                            <DockPanel Margin="10,0">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Viewport" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource AccentSoft}" BorderBrush="#245B76" BorderThickness="1" Padding="7,2" CornerRadius="3" Margin="12,0,0,0">
                                        <TextBlock x:Name="ViewportInfoText" Text="Zoom: 100% | Pan: 0, 0" Foreground="#BBDCEE" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="CurrentToolText" Text="Select" Visibility="Collapsed"/>
                                    <TextBlock x:Name="SegmentFirstVertexText" Text="None" Visibility="Collapsed"/>

                                    <Button x:Name="ViewportGridButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportGridButton_Click" ToolTip="Show / hide viewport grid">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Grid" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Grid"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportSnapButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportSnapButton_Click" ToolTip="Toggle snap to grid">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Magnet" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Snap"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportVertexesButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportVertexesButton_Click" ToolTip="Show / hide vertex points">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="VectorPoint" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Vertexes"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportSegmentsButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportSegmentsButton_Click" ToolTip="Show / hide segments">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="VectorLine" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Segments"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportDiscsButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportDiscsButton_Click" ToolTip="Show / hide discs">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CircleOutline" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Discs"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportPlanesButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportPlanesButton_Click" ToolTip="Show / hide planes">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AxisArrow" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Planes"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportInvisibleButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportInvisibleButton_Click" ToolTip="Show / hide invisible objects in editor">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="EyeOutline" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Invisible"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportMirrorButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportMirrorButton_Click" ToolTip="Mirror Mode: automatically create a mirrored copy when placing a new object">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Mirror" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Mirror"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ViewportResetButton" Style="{StaticResource ViewportMiniButton}" Click="ViewportResetButton_Click" ToolTip="Reset viewport">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FitToScreenOutline" Style="{StaticResource ViewportMiniIcon}"/>
                                            <TextBlock Text="Reset"/>
                                        </StackPanel>
                                    </Button>

                                    <Rectangle Width="1" Height="20" Fill="#343A45" Margin="7,0"/>
                                    <TextBlock x:Name="MousePositionText" Text="HaxBall X: 0  Y: 0" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Margin="0,36,0,0" Background="#3B2E29" ClipToBounds="True">
                            <Canvas x:Name="MapCanvas"
                                Background="#3B2E29"
                                ClipToBounds="True"
                                Focusable="True"
                                MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                                MouseMove="MapCanvas_MouseMove"
                                MouseWheel="MapCanvas_MouseWheel"
                                MouseDown="MapCanvas_MouseDown"
                                MouseUp="MapCanvas_MouseUp"
                                SizeChanged="MapCanvas_SizeChanged"/>
                        </Border>
                    </Grid>
                </Border>


                <GridSplitter x:Name="BottomPanelGridSplitter"
                              Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#242A33"
                              BorderBrush="#3A4350"
                              BorderThickness="0,1"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"
                              Cursor="SizeNS"
                              Visibility="Collapsed"
                              ToolTip="Drag to resize the bottom panel"/>

                <Border x:Name="BottomPanelHost"
                        Grid.Row="2"
                        Background="{StaticResource PanelDark}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Visibility="Collapsed">
                    <TabControl x:Name="BottomPanelTabControl"/>
                </Border>
            </Grid>

            <GridSplitter x:Name="RightPanelGridSplitter"
                          Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#242A33"
                          BorderBrush="#3A4350"
                          BorderThickness="1,0"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Cursor="SizeWE"
                          Visibility="Collapsed"
                          ToolTip="Drag to resize the right panel"/>

            <Border x:Name="RightPanelHost"
                    Grid.Column="4"
                    Background="{StaticResource PanelDark}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <TabControl x:Name="RightPanelTabControl">
                    <TabItem x:Name="InspectorTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Inspector"
                                       Tag="Inspector"
                                       ToolTip="Double-click or drag to detach this panel"
                                       PreviewMouseLeftButtonDown="PanelHeader_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="PanelHeader_PreviewMouseMove"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <Expander x:Name="SelectionExpander" Header="Selection / Coordinates" IsExpanded="True">
                                    <StackPanel>
                                        <TextBlock Text="Selected Object" Style="{StaticResource PropertyLabel}"/>
                                        <TextBox x:Name="SelectedObjectText" Text="None" IsReadOnly="True" Style="{StaticResource InputTextBox}"/>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Position / Data A" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PositionXTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Position / Data B" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PositionYTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#151A21" BorderBrush="#303844" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Selection Info" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="SelectionInfoTextBlock"
                                                           Text="No selection"
                                                           Foreground="{StaticResource TextMain}"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Expander x:Name="CollisionExpander" Header="Collision Checkboxes (legacy)" IsExpanded="False" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Collision Group" Style="{StaticResource PropertyLabel}"/>
                                                <WrapPanel>
                                                    <CheckBox x:Name="CGroupBallCheckBox" Content="ball" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupRedCheckBox" Content="red" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupBlueCheckBox" Content="blue" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CGroupWallCheckBox" Content="wall" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                </WrapPanel>
                                                <TextBlock Text="Collision Mask" Style="{StaticResource PropertyLabel}" Margin="0,10,0,3"/>
                                                <WrapPanel>
                                                    <CheckBox x:Name="CMaskBallCheckBox" Content="ball" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskRedCheckBox" Content="red" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskBlueCheckBox" Content="blue" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                    <CheckBox x:Name="CMaskWallCheckBox" Content="wall" Foreground="{StaticResource TextMain}" Margin="0,4,12,0" Checked="CollisionCheckBox_Changed" Unchecked="CollisionCheckBox_Changed"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="MultiPropertiesExpander" Header="Multi-Select Common Properties" IsExpanded="True" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Applies only to selected object types that support each property. Leave a field empty to keep it unchanged."
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiColorTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: #FFFFFF. Applies to Segment, Disc and Joint."/>
                                                <TextBlock Text="Trait" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiTraitTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Applies to Segment, Disc and Plane."/>
                                                <TextBlock Text="Visibility" Style="{StaticResource PropertyLabel}"/>
                                                <ComboBox x:Name="MultiVisComboBox" SelectedIndex="0" ToolTip="Applies to Segment, Disc and Plane vis extension.">
                                                    <ComboBoxItem Content="Keep"/>
                                                    <ComboBoxItem Content="True"/>
                                                    <ComboBoxItem Content="False"/>
                                                    <ComboBoxItem Content="Default"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="cMask" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiCMaskTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: ball, red, blue, wall. Applies to Segment, Disc and Plane."/>
                                                <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="MultiCGroupTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Example: wall. Applies to Segment, Disc and Plane."/>
                                                <Button Content="Apply Common Properties"
                                                        Style="{StaticResource SmallButton}"
                                                        HorizontalAlignment="Stretch"
                                                        Margin="0,16,0,0"
                                                        Click="ApplyMultiPropertiesButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="ObjectPropertiesExpander" Header="Object Properties" IsExpanded="True">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel x:Name="ObjectXFieldPanel">
                                                    <TextBlock Text="X" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectXTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="ObjectYFieldPanel">
                                                    <TextBlock Text="Y" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectYTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="RadiusFieldPanel">
                                                    <TextBlock Text="Radius" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="RadiusTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="CurveFieldPanel">
                                                    <TextBlock Text="Curve" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CurveTextBox" Text="0" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="InvMassFieldPanel">
                                                    <TextBlock Text="invMass" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="InvMassTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="DampingFieldPanel">
                                                    <TextBlock Text="damping" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="DampingTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <StackPanel x:Name="ColorFieldPanel">
                                                    <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="ObjectColorTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="BCoefFieldPanel">
                                                    <TextBlock Text="bCoef" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="BCoefTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="SpeedFieldPanel">
                                                    <TextBlock Text="speed X / Y" Style="{StaticResource PropertyLabel}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="SpeedXTextBox" Grid.Column="0" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                        <TextBox x:Name="SpeedYTextBox" Grid.Column="2" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="GravityFieldPanel">
                                                    <TextBlock Text="gravity X / Y" Style="{StaticResource PropertyLabel}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="GravityXTextBox" Grid.Column="0" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                        <TextBox x:Name="GravityYTextBox" Grid.Column="2" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="TraitFieldPanel">
                                                    <TextBlock Text="trait" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="TraitTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="BiasFieldPanel">
                                                    <TextBlock Text="bias" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="BiasTextBox" Text="" Style="{StaticResource InputTextBox}" LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel x:Name="VisFieldPanel">
                                                    <TextBlock Text="vis" Style="{StaticResource PropertyLabel}"/>
                                                    <ComboBox x:Name="VisComboBox" SelectionChanged="VisComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Default"/>
                                                        <ComboBoxItem Content="true"/>
                                                        <ComboBoxItem Content="false"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel x:Name="CollisionTextFieldsPanel" Margin="0,10,0,0">
                                            <TextBlock Text="Collision" Style="{StaticResource PropertyLabel}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="cMask" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CMaskTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Comma separated: ball, red, blue, wall, redKO, blueKO, c0..." LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                    <TextBox x:Name="CGroupTextBox" Text="" Style="{StaticResource InputTextBox}" ToolTip="Comma separated: ball, red, blue, wall, redKO, blueKO, c0..." LostFocus="ObjectPropertyTextBox_LostFocus" KeyDown="ObjectPropertyTextBox_KeyDown"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="GoalTeamExpander" Header="Goal Team" IsExpanded="False">
                                    <StackPanel>
                                        <ComboBox x:Name="GoalTeamComboBox" SelectedIndex="0" SelectionChanged="GoalTeamComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Red"/>
                                            <ComboBoxItem Content="Blue"/>
                                        </ComboBox>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Button Content="Set Red" Style="{StaticResource SmallButton}" Click="GoalTeamRedButton_Click"/>
                                            <Button Content="Set Blue" Style="{StaticResource SmallButton}" Click="GoalTeamBlueButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="JointToolExpander" Header="Joint Tool" IsExpanded="False">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="disc index 0" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="JointD0TextBox" Text="0" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="disc index 1" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="JointD1TextBox" Text="1" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Button Content="Add Joint From Indices" Style="{StaticResource SmallButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="AddJointButton_Click"/>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="BackgroundExpander" Header="Background" IsExpanded="False">
                                    <StackPanel>
                                        <TextBlock Text="Type" Style="{StaticResource PropertyLabel}"/>
                                        <ComboBox x:Name="BgTypeComboBox" SelectionChanged="BgTypeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="Grass"/>
                                            <ComboBoxItem Content="Hockey"/>
                                        </ComboBox>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Color" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgColorTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                                <TextBlock Text="Width" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgWidthTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Height" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgHeightTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                                <TextBlock Text="KickOff Radius" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BgKickOffRadiusTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Corner Radius" Style="{StaticResource PropertyLabel}"/>
                                        <TextBox x:Name="BgCornerRadiusTextBox" Style="{StaticResource InputTextBox}" LostFocus="BackgroundSettingTextBox_LostFocus" KeyDown="BackgroundSettingTextBox_KeyDown"/>
                                    </StackPanel>
                                </Expander>

                                <Expander x:Name="StadiumPhysicsExpander" Header="Stadium Physics" IsExpanded="True">
                                    <StackPanel>
                                        <TextBlock Text="These top-level .hbs values are edited when no object is selected. They are saved as canBeStored, playerPhysics and ballPhysics." Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                        <TextBlock Text="Stadium Properties" Style="{StaticResource SectionTitle}"/>
                                        <CheckBox x:Name="CanBeStoredCheckBox" Content="canBeStored" IsChecked="True" ToolTip="If true, the stadium can be saved/stored by HaxBall when supported."/>

                                        <TextBlock Text="Player Physics" Style="{StaticResource SectionTitle}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="gravity X / Y" Style="{StaticResource PropertyLabel}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="PlayerGravityXTextBox" Grid.Column="0" Text="0" Style="{StaticResource InputTextBox}"/>
                                                    <TextBox x:Name="PlayerGravityYTextBox" Grid.Column="2" Text="0" Style="{StaticResource InputTextBox}"/>
                                                </Grid>
                                                <TextBlock Text="radius" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerRadiusTextBox" Text="15" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="bCoef" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerBCoefTextBox" Text="0.5" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="invMass" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerInvMassTextBox" Text="0.5" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="damping" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerDampingTextBox" Text="0.96" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerCGroupTextBox" Text="red, blue" Style="{StaticResource InputTextBox}" ToolTip="Example: red, blue"/>
                                                <TextBlock Text="acceleration" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerAccelerationTextBox" Text="0.1" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Player Physics (Kick)" Style="{StaticResource SectionTitle}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="kickingAcceleration" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerKickingAccelerationTextBox" Text="0.07" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="kickingDamping" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerKickingDampingTextBox" Text="0.96" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="kickStrength" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerKickStrengthTextBox" Text="5" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="kickback" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="PlayerKickbackTextBox" Text="0" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Ball Physics" Style="{StaticResource SectionTitle}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="gravity X / Y" Style="{StaticResource PropertyLabel}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="BallGravityXTextBox" Grid.Column="0" Text="0" Style="{StaticResource InputTextBox}"/>
                                                    <TextBox x:Name="BallGravityYTextBox" Grid.Column="2" Text="0" Style="{StaticResource InputTextBox}"/>
                                                </Grid>
                                                <TextBlock Text="radius" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallRadiusTextBox" Text="10" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="bCoef" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallBCoefTextBox" Text="0.5" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="invMass" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallInvMassTextBox" Text="1" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="damping" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallDampingTextBox" Text="0.99" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="color" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallColorTextBox" Text="#FFFFFF" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="cMask" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallCMaskTextBox" Text="all" Style="{StaticResource InputTextBox}"/>
                                                <TextBlock Text="cGroup" Style="{StaticResource PropertyLabel}"/>
                                                <TextBox x:Name="BallCGroupTextBox" Text="ball" Style="{StaticResource InputTextBox}"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="Reset Defaults" Style="{StaticResource SmallButton}" Click="ResetStadiumPhysicsButton_Click"/>
                                            <Button Content="Apply Physics" Style="{StaticResource PrimaryTopButton}" Height="30" MinWidth="110" Margin="6,2,0,2" Click="ApplyStadiumPhysicsButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="LayersTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Layers"
                                       Tag="Layers"
                                       ToolTip="Double-click or drag to detach this panel"
                                       PreviewMouseLeftButtonDown="PanelHeader_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="PanelHeader_PreviewMouseMove"/>
                        </TabItem.Header>
                        <Grid Margin="10" Background="{StaticResource PanelDark}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Objects" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Search, filter, click to select, double-click to focus in viewport." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Search" Style="{StaticResource PropertyLabel}" Margin="0,0,0,3"/>
                                    <TextBox x:Name="LayersSearchTextBox"
                                             Style="{StaticResource InputTextBox}"
                                             ToolTip="Search object type, index, coordinates, color, collision values."
                                             TextChanged="LayersSearchTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Type Filter" Style="{StaticResource PropertyLabel}" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="LayersTypeFilterComboBox"
                                              SelectedIndex="0"
                                              SelectionChanged="LayersTypeFilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="All"/>
                                        <ComboBoxItem Content="Vertexes"/>
                                        <ComboBoxItem Content="Segments"/>
                                        <ComboBoxItem Content="Discs"/>
                                        <ComboBoxItem Content="Goals"/>
                                        <ComboBoxItem Content="Planes"/>
                                        <ComboBoxItem Content="Spawn Points"/>
                                        <ComboBoxItem Content="Joints"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Hide" Style="{StaticResource SmallButton}" Click="HideSelectedLayerButton_Click" ToolTip="Hide selected object(s) in the editor viewport"/>
                                <Button Content="Show All" Style="{StaticResource SmallButton}" Click="ShowAllLayersButton_Click" ToolTip="Show all hidden objects"/>
                                <Button Content="Lock" Style="{StaticResource SmallButton}" Click="LockSelectedLayerButton_Click" ToolTip="Lock selected object(s) against moving/deleting from viewport"/>
                                <Button Content="Unlock All" Style="{StaticResource SmallButton}" Click="UnlockAllLayersButton_Click" ToolTip="Unlock all objects"/>
                            </StackPanel>

                            <ListBox x:Name="ObjectsListBox"
                                     Grid.Row="3"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Background="#12151A"
                                     Foreground="{StaticResource TextMain}"
                                     BorderBrush="#333A46"
                                     SelectionChanged="ObjectsListBox_SelectionChanged"
                                     MouseDoubleClick="ObjectsListBox_MouseDoubleClick"/>
                        </Grid>
                    </TabItem>


                    <TabItem x:Name="ValidatorTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Validator"
                                       Tag="Validator"
                                       ToolTip="Double-click or drag to detach this panel"
                                       PreviewMouseLeftButtonDown="PanelHeader_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="PanelHeader_PreviewMouseMove"/>
                        </TabItem.Header>
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Stadium Validator" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Checks invalid indexes, unsafe values, colors and collision groups. Double-click a result to focus the related object." Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="#151A21" BorderBrush="#303844" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock x:Name="ValidationSummaryText" Text="Not validated yet." Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ValidationDetailsText" Text="Press Validate to scan the current stadium." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SmallButton}" Click="ValidateButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldCheckOutline" Width="14" Height="14" Foreground="{StaticResource TextMain}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Validate"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                            </Border>

                            <ListBox x:Name="ValidationResultsListBox"
                                     Grid.Row="2"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Background="#12151A"
                                     Foreground="{StaticResource TextMain}"
                                     BorderBrush="#333A46"
                                     MouseDoubleClick="ValidationResultsListBox_MouseDoubleClick"/>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="JsonTabItem">
                        <TabItem.Header>
                            <TextBlock Text="JSON"
                                       Tag="JSON"
                                       ToolTip="Double-click or drag to detach this panel"
                                       PreviewMouseLeftButtonDown="PanelHeader_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="PanelHeader_PreviewMouseMove"/>
                        </TabItem.Header>
                        <Grid Background="#1A1B1E">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#202124" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <DockPanel Margin="10,0">
                                    <TextBlock Text="Editable Stadium JSON" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <Button Content="Apply JSON" Style="{StaticResource SmallButton}" Click="ApplyJsonButton_Click"/>
                                        <Button Content="Refresh" Style="{StaticResource SmallButton}" Click="RefreshJsonButton_Click"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Grid.Row="1" Margin="10" Background="#0F1012" BorderBrush="#34373C" BorderThickness="1">
                                <TextBox x:Name="JsonPreviewTextBox"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalAlignment="Stretch"
                                         HorizontalAlignment="Stretch"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Padding="12"
                                         Background="#0F1012"
                                         Foreground="#DCDCDC"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         TextChanged="JsonPreviewTextBox_TextChanged"/>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="HistoryTabItem">
                        <TabItem.Header>
                            <TextBlock Text="History"
                                       Tag="History"
                                       ToolTip="Double-click or drag to detach this panel"
                                       PreviewMouseLeftButtonDown="PanelHeader_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="PanelHeader_PreviewMouseMove"/>
                        </TabItem.Header>
                        <Grid Background="#1A1B1E">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#202124" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="10">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                                            <TextBlock Text="History" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="HistorySummaryText" Text="No edit history yet." Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="HistoryUndoButton" Style="{StaticResource SmallButton}" Click="HistoryUndoButton_Click" ToolTip="Undo last action">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Undo" Width="14" Height="14" Foreground="{StaticResource TextMain}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Undo"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="HistoryRedoButton" Style="{StaticResource SmallButton}" Click="HistoryRedoButton_Click" ToolTip="Redo last undone action">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Redo" Width="14" Height="14" Foreground="{StaticResource TextMain}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Redo"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border Background="#11161D" BorderBrush="#303845" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,10,0,0">
                                        <DockPanel>
                                            <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16" Foreground="{StaticResource TextMuted}" Margin="0,0,7,0" DockPanel.Dock="Left"/>
                                            <TextBlock Text="This panel shows the current undo and redo stacks. Use Ctrl+Z / Ctrl+Y or the buttons above."
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="HistoryListBox"
                                     Grid.Row="1"
                                     FontSize="12"
                                     Background="#12151A"
                                     Foreground="{StaticResource TextMain}"
                                     BorderBrush="#333A46"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0F6FA5" BorderBrush="#0A577F" BorderThickness="0,1,0,0">
            <DockPanel Margin="10,0">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="White" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock x:Name="ObjectCountText" Text="Vertexes: 0 | Segments: 0 | Goals: 0 | Planes: 0 | Discs: 0 | Joints: 0 | Spawns: 0" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>


        <TabControl x:Name="HiddenPanelTabControl" Visibility="Collapsed"/>

        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="4"
              Panel.ZIndex="999"
              Background="#080A0D"
              Visibility="Visible">
            <Grid>
                <Grid.Background>
                    <RadialGradientBrush Center="0.50,0.42" GradientOrigin="0.50,0.42" RadiusX="0.82" RadiusY="0.82">
                        <GradientStop Color="#14202B" Offset="0"/>
                        <GradientStop Color="#080A0D" Offset="0.62"/>
                        <GradientStop Color="#050608" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>

                <Border x:Name="SplashContentCard"
                        Width="520"
                        Height="300"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#11151C"
                        BorderBrush="#263241"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="34" ShadowDepth="0" Opacity="0.40" Color="#000000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="178"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#0B0F14"
                                CornerRadius="12,0,0,12">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="78"
                                            Height="78"
                                            CornerRadius="19"
                                            Background="#101821"
                                            BorderBrush="#2FB7E8"
                                            BorderThickness="2"
                                            HorizontalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.48" Color="#2FB7E8"/>
                                        </Border.Effect>
                                        <TextBlock Text="H"
                                                   Foreground="#2FB7E8"
                                                   FontSize="46"
                                                   FontWeight="Black"
                                                   FontFamily="Segoe UI Semibold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="HaxStudio"
                                               Foreground="#F2FBFF"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Margin="0,15,0,0"/>

                                    <TextBlock Text="Version 1.0.0"
                                               Foreground="#6E7A89"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <TextBlock Text="Private build"
                                           Foreground="#536171"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,13"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#263241"/>

                        <Grid Grid.Column="2" Margin="24,22,24,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Modern HaxBall Stadium Editor"
                                           Foreground="#E8EDF4"
                                           FontSize="17"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Preparing editor workspace"
                                           Foreground="#8D9AAB"
                                           FontSize="11.5"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="Loading modules"
                                           Foreground="#657181"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="SplashStatusText"
                                           Text="Starting HaxStudio..."
                                           Foreground="#DDE7F3"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="SplashDetailText"
                                           Text="Initializing application shell"
                                           Foreground="#93A0B1"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MinHeight="30"
                                           Margin="0,0,0,13"/>

                                <ProgressBar x:Name="SplashProgressBar"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Width="270"
                                             Height="5"
                                             HorizontalAlignment="Left"
                                             Foreground="#2FB7E8"
                                             Background="#242832"
                                             BorderThickness="0"/>

                                <TextBlock x:Name="SplashPercentText"
                                           Text="0%"
                                           Foreground="#657181"
                                           FontSize="11"
                                           HorizontalAlignment="Left"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <TextBlock Text="Loading HaxStudio. Please wait."
