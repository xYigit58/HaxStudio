<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>HaxBallEditorLogo.ico</ApplicationIcon>
    <AssemblyTitle>HaxStudio</AssemblyTitle>
    <RootNamespace>haxballeditor</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="HaxBallEditorLogo.ico" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="HaxBallEditorLogo.ico" />
  </ItemGroup>

</Project>
